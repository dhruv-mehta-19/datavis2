{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where Melbourne Drinks",
    "subtitle": [
      "Every cafe and restaurant in the City of Melbourne.",
      "Click a neighbourhood or size category in the legend to filter. Click again to deselect, hold Shift for multiple.",
      "Note: data covers City of Melbourne council only \u2014 St Kilda, Richmond and most of South Yarra are in other councils."
    ],
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 12,
    "subtitleColor": "#666",
    "color": "#3C1F0F",
    "font": "Georgia, Times New Roman, serif",
    "subtitleFont": "Georgia, Times New Roman, serif"
  },
  "width": 780,
  "height": 600,
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/dhruv-mehta-19/datavis2/refs/heads/main/small-areas-for-census-of-land-use-and-employment-clue.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#F5F1E8",
        "stroke": "#D89651",
        "strokeWidth": 0.8
      },
      "encoding": {
        "tooltip": [
          {
            "field": "properties.featurenam",
            "type": "nominal",
            "title": "Neighbourhood"
          }
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/dhruv-mehta-19/datavis2/refs/heads/main/cafes-and-restaurants-with-seating-capacity.csv"
      },
      "transform": [
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "Number of seats",
              "as": "total_seats"
            }
          ],
          "groupby": [
            "Trading name",
            "Longitude",
            "Latitude",
            "CLUE small area"
          ]
        },
        {
          "calculate": "datum.total_seats < 80 ? 'Small (< 80 seats)' : datum.total_seats < 200 ? 'Medium (80\u2013199)' : 'Large (200+)'",
          "as": "size_category"
        }
      ],
      "params": [
        {
          "name": "area_select",
          "select": {
            "type": "point",
            "fields": [
              "CLUE small area"
            ]
          },
          "bind": "legend"
        },
        {
          "name": "size_select",
          "select": {
            "type": "point",
            "fields": [
              "size_category"
            ]
          },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "circle",
        "stroke": "#3C1F0F",
        "strokeWidth": 0.5
      },
      "encoding": {
        "longitude": {
          "field": "Longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "Latitude",
          "type": "quantitative"
        },
        "size": {
          "field": "total_seats",
          "type": "quantitative",
          "scale": {
            "range": [
              10,
              350
            ],
            "domain": [
              10,
              500
            ]
          },
          "legend": {
            "title": "Total seats",
            "orient": "right",
            "offset": 10,
            "values": [
              50,
              100,
              200,
              500
            ]
          }
        },
        "color": {
          "field": "size_category",
          "type": "nominal",
          "scale": {
            "domain": [
              "Small (< 80 seats)",
              "Medium (80\u2013199)",
              "Large (200+)"
            ],
            "range": [
              "#D89651",
              "#6B3410",
              "#3C1F0F"
            ]
          }
        },
        "opacity": {
          "condition": {
            "test": {
              "and": [
                {
                  "param": "area_select"
                },
                {
                  "param": "size_select"
                }
              ]
            },
            "value": 0.75
          },
          "value": 0.08
        },
        "tooltip": [
          {
            "field": "Trading name",
            "type": "nominal",
            "title": "Venue"
          },
          {
            "field": "total_seats",
            "type": "quantitative",
            "title": "Seats"
          },
          {
            "field": "size_category",
            "type": "nominal",
            "title": "Size"
          },
          {
            "field": "CLUE small area",
            "type": "nominal",
            "title": "Area"
          }
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/dhruv-mehta-19/datavis2/refs/heads/main/cafes-and-restaurants-with-seating-capacity.csv"
      },
      "transform": [
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "Number of seats",
              "as": "total_seats"
            }
          ],
          "groupby": [
            "CLUE small area"
          ]
        },
        {
          "filter": "datum['CLUE small area'] != null"
        }
      ],
      "mark": {
        "type": "point",
        "opacity": 0
      },
      "encoding": {
        "color": {
          "field": "CLUE small area",
          "type": "nominal",
          "legend": {
            "title": "Neighbourhood",
            "orient": "right",
            "offset": 10,
            "labelLimit": 150,
            "symbolType": "square"
          },
          "scale": {
            "range": [
              "#6B3410"
            ]
          }
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "lon": 144.9633,
            "lat": -37.8136,
            "label": "CBD",
            "size": 16
          },
          {
            "lon": 144.971,
            "lat": -37.804,
            "label": "Carlton",
            "size": 14
          },
          {
            "lon": 144.945,
            "lat": -37.8236,
            "label": "Docklands",
            "size": 14
          },
          {
            "lon": 144.9647,
            "lat": -37.826,
            "label": "Southbank",
            "size": 14
          },
          {
            "lon": 144.9526,
            "lat": -37.8005,
            "label": "North Melbourne",
            "size": 12
          },
          {
            "lon": 144.9844,
            "lat": -37.8181,
            "label": "East Melbourne",
            "size": 12
          },
          {
            "lon": 144.946,
            "lat": -37.81,
            "label": "West Melbourne",
            "size": 12
          },
          {
            "lon": 144.919,
            "lat": -37.825,
            "label": "Port Melbourne",
            "size": 11
          },
          {
            "lon": 144.9533,
            "lat": -37.786,
            "label": "Parkville",
            "size": 12
          },
          {
            "lon": 144.93,
            "lat": -37.795,
            "label": "Kensington",
            "size": 12
          }
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "text",
            "fontWeight": "bold",
            "stroke": "white",
            "strokeWidth": 3,
            "fill": "white"
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label"
            },
            "size": {
              "field": "size",
              "type": "quantitative",
              "scale": null,
              "legend": null
            }
          }
        },
        {
          "mark": {
            "type": "text",
            "fontWeight": "bold",
            "color": "#3C1F0F"
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label"
            },
            "size": {
              "field": "size",
              "type": "quantitative",
              "scale": null,
              "legend": null
            }
          }
        }
      ]
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "transparent",
    "font": "Georgia, Times New Roman, serif"
  }
}
