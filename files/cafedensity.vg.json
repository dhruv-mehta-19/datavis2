{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Every Cafe in Melbourne, by Size",
    "subtitle": [
      "Each dot is one cafe or restaurant, placed by its seat count and grouped by neighbourhood.",
      "Most are small; a scattered few are large. The CBD has the most of both \u2014 and the biggest outliers."
    ],
    "anchor": "start",
    "fontSize": 15,
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "color": "#3C1F0F",
    "font": "Georgia, 'Times New Roman', serif",
    "subtitleFont": "Georgia, 'Times New Roman', serif",
    "labelFont": "Georgia, 'Times New Roman', serif"
  },
  "width": 460,
  "height": 360,
  "data": {
    "url": "https://raw.githubusercontent.com/dhruv-mehta-19/datavis2/refs/heads/main/cafes-and-restaurants-with-seating-capacity.csv"
  },
  "transform": [
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Number of seats",
          "as": "seats"
        }
      ],
      "groupby": [
        "Trading name",
        "CLUE small area"
      ]
    },
    {
      "filter": "datum['CLUE small area'] == 'Melbourne (CBD)' || datum['CLUE small area'] == 'Carlton' || datum['CLUE small area'] == 'Docklands' || datum['CLUE small area'] == 'Southbank' || datum['CLUE small area'] == 'North Melbourne'"
    },
    {
      "filter": "datum.seats > 0"
    },
    {
      "calculate": "datum['CLUE small area'] == 'Melbourne (CBD)' ? 0 : datum['CLUE small area'] == 'Carlton' ? 1 : datum['CLUE small area'] == 'Docklands' ? 2 : datum['CLUE small area'] == 'Southbank' ? 3 : 4",
      "as": "xband"
    },
    {
      "calculate": "datum.xband + (random() - 0.5) * 0.65",
      "as": "jx"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "circle",
        "size": 22,
        "opacity": 0.5,
        "stroke": "white",
        "strokeWidth": 0.3,
        "labelFont": "Georgia, 'Times New Roman', serif",
        "titleFont": "Georgia, 'Times New Roman', serif"
      },
      "encoding": {
        "x": {
          "field": "jx",
          "type": "quantitative",
          "scale": {
            "domain": [
              -0.6,
              4.6
            ]
          },
          "axis": {
            "values": [
              0,
              1,
              2,
              3,
              4
            ],
            "labelExpr": "['CBD','Carlton','Docklands','Southbank','N. Melb'][datum.value]",
            "title": null,
            "labelFontSize": 11,
            "labelColor": "#3C1F0F",
            "labelFont": "Georgia, 'Times New Roman', serif",
            "grid": false,
            "domainColor": "#D89651",
            "titleFont": "Georgia, 'Times New Roman', serif"
          }
        },
        "y": {
          "field": "seats",
          "type": "quantitative",
          "title": "Seats per venue",
          "axis": {
            "titleColor": "#3C1F0F",
            "titleFont": "Georgia, 'Times New Roman', serif",
            "labelColor": "#666",
            "labelFont": "Georgia, 'Times New Roman', serif",
            "grid": true,
            "gridColor": "#f5f5f5"
          }
        },
        "color": {
          "field": "seats",
          "type": "quantitative",
          "scale": {
            "range": [
              "#E8C9A0",
              "#D89651",
              "#6B3410",
              "#3C1F0F"
            ]
          },
          "legend": {
            "title": "Seats",
            "orient": "right",
            "labelFont": "Georgia, 'Times New Roman', serif",
            "titleFont": "Georgia, 'Times New Roman', serif"
          }
        },
        "tooltip": [
          {
            "field": "Trading name",
            "type": "nominal",
            "title": "Venue"
          },
          {
            "field": "CLUE small area",
            "type": "nominal",
            "title": "Neighbourhood"
          },
          {
            "field": "seats",
            "type": "quantitative",
            "title": "Seats"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "transparent",
    "font": "Georgia, 'Times New Roman', serif",
    "axis": {
      "labelFont": "Georgia, 'Times New Roman', serif",
      "titleFont": "Georgia, 'Times New Roman', serif"
    },
    "legend": {
      "labelFont": "Georgia, 'Times New Roman', serif",
      "titleFont": "Georgia, 'Times New Roman', serif"
    },
    "header": {
      "labelFont": "Georgia, 'Times New Roman', serif",
      "titleFont": "Georgia, 'Times New Roman', serif"
    },
    "title": {
      "font": "Georgia, 'Times New Roman', serif",
      "subtitleFont": "Georgia, 'Times New Roman', serif",
      "labelFont": "Georgia, 'Times New Roman', serif"
    }
  }
}
