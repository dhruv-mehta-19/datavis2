{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where Your $5 Goes",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 12,
    "subtitleColor": "#666",
    "color": "#3C1F0F"
  },
  "width": 480,
  "height": 360,
  "data": {
    "values": [
      {"scenario": "Busy day (200 cups)", "component": "GST", "amount": 0.45, "order": 1},
      {"scenario": "Busy day (200 cups)", "component": "Beans", "amount": 0.38, "order": 2},
      {"scenario": "Busy day (200 cups)", "component": "Milk & cup", "amount": 0.60, "order": 3},
      {"scenario": "Busy day (200 cups)", "component": "Labour", "amount": 1.35, "order": 4},
      {"scenario": "Busy day (200 cups)", "component": "Gross profit", "amount": 2.22, "order": 5},
      {"scenario": "Quiet day (100 cups)", "component": "GST", "amount": 0.45, "order": 1},
      {"scenario": "Quiet day (100 cups)", "component": "Beans", "amount": 0.38, "order": 2},
      {"scenario": "Quiet day (100 cups)", "component": "Milk & cup", "amount": 0.60, "order": 3},
      {"scenario": "Quiet day (100 cups)", "component": "Labour", "amount": 2.70, "order": 4},
      {"scenario": "Quiet day (100 cups)", "component": "Gross profit", "amount": 0.87, "order": 5}
    ]
  },
  "encoding": {
    "x": {
      "field": "scenario",
      "type": "nominal",
      "title": null,
      "sort": ["Busy day (200 cups)", "Quiet day (100 cups)"],
      "axis": {"labelFontSize": 12, "labelFontWeight": "bold", "labelColor": "#3C1F0F", "labelAngle": 0}
    },
    "y": {
      "field": "amount",
      "type": "quantitative",
      "title": "Cost / profit per cup (AUD)",
      "stack": "zero",
      "axis": {"format": "$.2f", "titleColor": "#3C1F0F", "labelColor": "#666", "grid": false}
    },
    "color": {
      "field": "component",
      "type": "nominal",
      "title": "Where the money goes",
      "sort": ["GST", "Beans", "Milk & cup", "Labour", "Gross profit"],
      "scale": {
        "domain": ["GST", "Beans", "Milk & cup", "Labour", "Gross profit"],
        "range": ["#E8D5B7", "#D89651", "#B8702F", "#6B3410", "#3C1F0F"]
      },
      "legend": {"orient": "right", "offset": 10, "titleColor": "#3C1F0F", "labelColor": "#3C1F0F"}
    },
    "order": {"field": "order", "type": "quantitative"}
  },
  "layer": [
    {
      "mark": {"type": "bar", "width": {"band": 0.55}, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "tooltip": [
          {"field": "scenario", "type": "nominal", "title": "Day"},
          {"field": "component", "type": "nominal", "title": "Where the money goes"},
          {"field": "amount", "type": "quantitative", "title": "Amount", "format": "$.2f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 10, "fontWeight": "bold"},
      "encoding": {
        "text": {"field": "amount", "type": "quantitative", "format": "$.2f"},
        "color": {
          "condition": {
            "test": "datum.component === 'Labour' || datum.component === 'Gross profit'",
            "value": "white"
          },
          "value": "#3C1F0F"
        },
        "y": {"field": "amount", "type": "quantitative", "stack": "zero", "bandPosition": 0.5}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "background": "white",
    "axis": {"domainColor": "#D89651"}
  }
}
