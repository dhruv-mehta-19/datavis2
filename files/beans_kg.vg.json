{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Premium Beans vs Bulk Beans",
    "subtitle": "Price per kilogram against quantity imported",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 12,
    "subtitleColor": "#666",
    "color": "#3C1F0F",
    "font": "Georgia, 'Times New Roman', serif",
    "subtitleFont": "Georgia, 'Times New Roman', serif",
    "labelFont": "Georgia, 'Times New Roman', serif"
  },
  "width": 460,
  "height": 460,
  "data": {
    "url": "https://raw.githubusercontent.com/dhruv-mehta-19/datavis2/refs/heads/main/coffee_imports_2023.csv"
  },
  "transform": [
    {
      "calculate": "datum.value_usd_thousands * 1000",
      "as": "value_usd_full"
    },
    {
      "calculate": "datum.value_usd_full / datum.quantity",
      "as": "price_per_kg"
    },
    {
      "calculate": "datum.value_usd_full < 1000000 ? 'Small (< $1M)' : datum.value_usd_full < 10000000 ? 'Mid ($1M\u2013$10M)' : datum.value_usd_full < 50000000 ? 'Large ($10M\u2013$50M)' : 'Very Large ($50M+)'",
      "as": "trade_category"
    },
    {
      "filter": "datum.quantity > 1000"
    },
    {
      "filter": "datum.partner != 'Australia'"
    }
  ],
  "layer": [
    {
      "data": {
        "values": [
          {
            "y": 5.67
          }
        ]
      },
      "mark": {
        "type": "rule",
        "stroke": "#999",
        "strokeWidth": 1,
        "strokeDash": [
          4,
          3
        ],
        "labelFont": "Georgia, 'Times New Roman', serif",
        "titleFont": "Georgia, 'Times New Roman', serif"
      },
      "encoding": {
        "y": {
          "field": "y",
          "type": "quantitative"
        }
      }
    },
    {
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "fields": [
              "partner"
            ],
            "clear": "pointerout"
          }
        },
        {
          "name": "category_select",
          "select": {
            "type": "point",
            "fields": [
              "trade_category"
            ]
          },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "circle",
        "color": "#6B3410",
        "stroke": "#3C1F0F",
        "strokeWidth": 0.5,
        "labelFont": "Georgia, 'Times New Roman', serif",
        "titleFont": "Georgia, 'Times New Roman', serif"
      },
      "encoding": {
        "x": {
          "field": "quantity",
          "type": "quantitative",
          "title": "Quantity imported (kg \u2014 log scale)",
          "scale": {
            "type": "log"
          },
          "axis": {
            "format": "~s",
            "values": [
              100,
              1000,
              10000,
              100000,
              1000000,
              10000000,
              100000000
            ],
            "grid": true,
            "gridColor": "#f0f0f0",
            "gridOpacity": 0.6,
            "titleColor": "#3C1F0F",
            "labelColor": "#666",
            "labelFont": "Georgia, 'Times New Roman', serif",
            "titleFont": "Georgia, 'Times New Roman', serif"
          }
        },
        "y": {
          "field": "price_per_kg",
          "type": "quantitative",
          "title": "Price per kg (USD)",
          "scale": {
            "type": "log",
            "domain": [
              1.8,
              75
            ]
          },
          "axis": {
            "format": "$,.2f",
            "values": [
              2,
              3,
              5,
              8,
              15,
              30,
              60
            ],
            "grid": true,
            "gridColor": "#f0f0f0",
            "gridOpacity": 0.6,
            "titleColor": "#3C1F0F",
            "labelColor": "#666",
            "labelFont": "Georgia, 'Times New Roman', serif",
            "titleFont": "Georgia, 'Times New Roman', serif"
          }
        },
        "size": {
          "field": "value_usd_full",
          "type": "quantitative",
          "scale": {
            "range": [
              40,
              600
            ]
          },
          "legend": null
        },
        "color": {
          "field": "trade_category",
          "type": "nominal",
          "scale": {
            "domain": [
              "Small (< $1M)",
              "Mid ($1M\u2013$10M)",
              "Large ($10M\u2013$50M)",
              "Very Large ($50M+)"
            ],
            "range": [
              "#D89651",
              "#B8702F",
              "#6B3410",
              "#3C1F0F"
            ]
          },
          "legend": {
            "title": "Click trade category to filter",
            "orient": "right",
            "symbolType": "circle",
            "labelFont": "Georgia, 'Times New Roman', serif",
            "titleFont": "Georgia, 'Times New Roman', serif"
          }
        },
        "opacity": {
          "condition": {
            "test": {
              "and": [
                {
                  "param": "hover",
                  "empty": true
                },
                {
                  "param": "category_select"
                }
              ]
            },
            "value": 0.75
          },
          "value": 0.1
        },
        "tooltip": [
          {
            "field": "partner",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "price_per_kg",
            "type": "quantitative",
            "title": "Price per kg",
            "format": "$,.2f"
          },
          {
            "field": "quantity",
            "type": "quantitative",
            "title": "Quantity (kg)",
            "format": "~s"
          },
          {
            "field": "value_usd_full",
            "type": "quantitative",
            "title": "Total value",
            "format": "$~s"
          },
          {
            "field": "trade_category",
            "type": "nominal",
            "title": "Category"
          }
        ]
      }
    },
