{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Australia's Top 10 Coffee Suppliers",
    "subtitle": "By import value, 2023 (USD)",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "subtitleColor": "#666"
  },
  "width": 500,
  "height": 380,
  "data": {
    "url": "https://raw.githubusercontent.com/dhruv-mehta-19/datavis2/refs/heads/main/coffee_imports_2023.csv"
  },
  "transform": [
    {"calculate": "datum.value_usd_thousands * 1000", "as": "value_usd_full"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "value_usd_full", "order": "descending"}]
    },
    {"filter": "datum.rank <= 10"}
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 3, "color": "#744c30"},
      "encoding": {
        "y": {
          "field": "partner",
          "type": "nominal",
          "sort": {"field": "rank", "order": "ascending"},
          "title": null,
          "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "value_usd_full",
          "type": "quantitative",
          "title": "Import value (USD)",
          "axis": {"format": "$,.0s", "values": [0, 20000000, 40000000, 60000000, 80000000, 100000000, 120000000]}
        },
        "tooltip": [
          {"field": "partner", "type": "nominal", "title": "Country"},
          {"field": "value_usd_full", "type": "quantitative", "title": "Import value", "format": "$,.0f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "baseline": "middle", "dx": 5, "fontSize": 11, "color": "#000000"},
      "encoding": {
        "y": {
          "field": "partner",
          "type": "nominal",
          "sort": {"field": "value_usd_full", "op": "max", "order": "descending"}
        },
        "x": {"field": "value_usd_full", "type": "quantitative"},
        "text": {"field": "value_usd_full", "type": "quantitative", "format": "$,.0f"}
      }
    },
    {
      "data": {
        "values": [
          {"y_anchor": "Brazil", "x_anchor": 112085000, "y_label": "Colombia", "x_label": 95000000, "label": "Nearly double  the amount Colombia imports"}
        ]
      },
      "layer": [
        {
          "mark": {"type": "rule", "stroke": "#000000", "strokeWidth": 1},
          "encoding": {
            "x": {"field": "x_anchor", "type": "quantitative"},
            "x2": {"field": "x_label"},
            "y": {"field": "y_anchor", "type": "nominal"},
            "y2": {"field": "y_label"}
          }
        },
        {
          "mark": {"type": "text", "align": "left", "baseline": "middle", "fontSize": 11, "fontStyle": "italic", "color": "#000000", "dx": 5},
          "encoding": {
            "x": {"field": "x_label", "type": "quantitative"},
            "y": {"field": "y_label", "type": "nominal"},
            "text": {"field": "label"}
          }
        }
      ]
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}
