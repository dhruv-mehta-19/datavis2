{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Explore Australia's Coffee Suppliers by Region",
    "subtitle": "Use the dropdown to filter suppliers by region. Import value, 2023.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 12,
    "subtitleColor": "#666",
    "color": "#3C1F0F"
  },
  "width": 560,
  "height": 420,
  "data": {
    "values": [
      {"country": "Brazil", "value": 112085, "region": "Latin America"},
      {"country": "Colombia", "value": 63675, "region": "Latin America"},
      {"country": "Honduras", "value": 38887, "region": "Latin America"},
      {"country": "Papua New Guinea", "value": 35247, "region": "Asia-Pacific"},
      {"country": "Vietnam", "value": 32197, "region": "Asia-Pacific"},
      {"country": "Ethiopia", "value": 29361, "region": "Africa"},
      {"country": "India", "value": 19416, "region": "Asia-Pacific"},
      {"country": "Nicaragua", "value": 14133, "region": "Latin America"},
      {"country": "Peru", "value": 13477, "region": "Latin America"},
      {"country": "Guatemala", "value": 13246, "region": "Latin America"},
      {"country": "Kenya", "value": 12135, "region": "Africa"},
      {"country": "Indonesia", "value": 8618, "region": "Asia-Pacific"},
      {"country": "El Salvador", "value": 6475, "region": "Latin America"},
      {"country": "Costa Rica", "value": 6411, "region": "Latin America"},
      {"country": "Tanzania", "value": 4200, "region": "Africa"},
      {"country": "Uganda", "value": 3100, "region": "Africa"}
    ]
  },
  "params": [
    {
      "name": "Region",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All", "Latin America", "Asia-Pacific", "Africa"],
        "name": "Choose region: "
      }
    }
  ],
  "transform": [
    {"filter": "Region == 'All' || datum.region == Region"},
    {"calculate": "datum.value * 1000", "as": "value_usd"}
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 2},
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": "-x",
          "title": null,
          "axis": {"labelFontSize": 12, "labelColor": "#3C1F0F"}
        },
        "x": {
          "field": "value_usd",
          "type": "quantitative",
          "title": "Import value (USD)",
          "axis": {
            "titleColor": "#3C1F0F",
            "labelColor": "#666",
            "grid": false,
            "format": "~s",
            "labelExpr": "replace(datum.label, 'G', 'B')"
          }
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "scale": {
            "domain": ["Latin America", "Asia-Pacific", "Africa"],
            "range": ["#6B3410", "#B8702F", "#D89651"]
          },
          "legend": {"title": "Region", "orient": "bottom-right"}
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "region", "type": "nominal", "title": "Region"},
          {"field": "value_usd", "type": "quantitative", "title": "Value (USD)", "format": "$~s"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 10, "color": "#3C1F0F"},
      "encoding": {
        "y": {"field": "country", "type": "nominal", "sort": "-x"},
        "x": {"field": "value_usd", "type": "quantitative"},
        "text": {"field": "value_usd", "type": "quantitative", "format": "~s"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "background": "transparent",
    "axis": {"domainColor": "#D89651"}
  }
}
